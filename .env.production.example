APP_NAME="GlobalDropship"
APP_ENV=production
APP_KEY=base64:GENERATE_ON_SERVER_WITH_PHP_ARTISAN_KEY_GENERATE
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dropship_platform
DB_USERNAME=dropship_user
DB_PASSWORD=CHANGE_ME

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CHANGE_ME_OR_NULL_FOR_LOCAL_REDIS
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

STRIPE_KEY=CHANGE_ME_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET=CHANGE_ME_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=CHANGE_ME_STRIPE_WEBHOOK_SECRET

PAYPAL_CLIENT_ID=CHANGE_ME
PAYPAL_CLIENT_SECRET=CHANGE_ME
PAYPAL_MODE=live

EASYPOST_API_KEY=CHANGE_ME
OPEN_EXCHANGE_APP_ID=CHANGE_ME
CLOUDINARY_URL=cloudinary://CHANGE_ME_API_KEY:CHANGE_ME_API_SECRET@CHANGE_ME_CLOUD_NAME

GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URL=https://yourdomain.com/auth/google/callback

FACEBOOK_CLIENT_ID=CHANGE_ME
FACEBOOK_CLIENT_SECRET=CHANGE_ME
FACEBOOK_REDIRECT_URL=https://yourdomain.com/auth/facebook/callback

VITE_APP_NAME="${APP_NAME}"
VITE_TAWK_PROPERTY_ID=CHANGE_ME
VITE_TAWK_WIDGET_ID=CHANGE_ME
